# GHOSTTRACE Environment Configuration
# Copy to .env and populate before running

# Flask
SECRET_KEY=change-this-to-a-random-secret-key
FLASK_ENV=development

# Anthropic API
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Mode: true = local homelab, false = hosted/render
LOCAL_MODE=true

# Database
DATABASE_URL=sqlite:///ghosttrace.db

# Rate limiting (AI calls per user per day)
DAILY_AI_LIMIT=20
HINTS_PER_SESSION=3

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
